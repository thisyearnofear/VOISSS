# Routeway API Configuration
ROUTEWAY_API_KEY=your_routeway_api_key_here

# ElevenLabs Agent Tools
# Optional bearer token for securing tool endpoints (best practice)
# If set, platform-stats and blockchain-stats endpoints will require this token
ELEVENLABS_AGENT_TOKEN=your_secure_bearer_token_here

# VoiceRecords Contract (Base blockchain)
NEXT_PUBLIC_VOICE_RECORDS_CONTRACT=0x226f8f5de4b3688B286998355B526bcD6956b339
NEXT_PUBLIC_VOICE_LICENSE_MARKET_ADDRESS=0xYourMarketplaceContractAddress

# AI Models (Server-side)
GEMINI_API_KEY=your_gemini_api_key
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# ACP Compute Credits (Virtuals Protocol - Primary AI Provider)
# Get credits at https://os.virtuals.io/community#credits
# This is the PRIMARY provider - free Venice AI inference for Base builders
ACP_COMPUTE_KEY=your_acp_compute_key_from_virtuals_console
ACP_AGENT_ID=019e98c7-2d39-7374-abaf-87d44e717c3f

# ACP Listener Configuration (Proactive Agent Discovery)
# Enable autonomous job discovery and bidding
# All three offerings: VoiceVocalize, VoiceInsight, VoiceClone
ACP_OFFERING_IDS=019e98e8-f262-7aa9-938b-73664bae4fcd,019e9bb1-5f8c-76c9-8f92-685af00b8c22,019e9bb1-9e4d-7fb1-bb47-adb879d978c0
ACP_AUTO_BID=false
ACP_MIN_BUDGET=0.01
ACP_RESPONSE_TIME_MS=30000
ACP_WEBHOOK_URL=https://voisss.netlify.app

# Venice AI (Direct API - Fallback if ACP credits exhausted)
VENICE_API_KEY=your_venice_api_key

# Base RPC URL (public - safe to expose)
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org

# Coinbase Developer Platform (CDP) - x402 Facilitator
# Required for x402 micropayment verification/settlement
# Get keys at https://portal.cdp.coinbase.com/projects/api-keys
CDP_API_KEY_ID=your_cdp_api_key_id
CDP_API_KEY_SECRET=your_cdp_api_key_secret

# Database Connection (server-side only - keep private)
DATABASE_URL=postgresql://user:password@host:port/voisss

# Redis Connection (server-side only - keep private)
# Required for distributed usage tracking and rate limiting
# Used by PaymentRouter for tracking agent usage across multiple servers
REDIS_URL=redis://username:password@host:port/database

# x402 Payment Configuration
# Address that receives x402 payments (USDC on Base)
X402_PAY_TO_ADDRESS=0xYourPaymentRecipientAddress

# OWS Multi-Chain Payment Recipients (Optional)
# If not set, X402_PAY_TO_ADDRESS will be used for all EVM chains
# For non-EVM chains, these are required
OWS_SOLANA_RECIPIENT=YourSolanaAddressHere
OWS_COSMOS_RECIPIENT=cosmos1...
OWS_TON_RECIPIENT=EQ...
OWS_XRP_RECIPIENT=r...
